# Leave empty for same-origin production access to /api/admin and /tunnel.
# Set to http://127.0.0.1:8080 when serving the website separately from the Relay.
VITE_API_BASE_URL=

# Vite dev server proxy target for local Relay development.
VITE_PROXY_TARGET=http://127.0.0.1:8080

# Host port used by compose.yml when serving the static website container.
WEBSITE_HTTP_PORT=11963
